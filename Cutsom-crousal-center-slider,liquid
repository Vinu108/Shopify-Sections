<script>
(function () {

  function getCfg() {
    var vw = document.documentElement.clientWidth || window.innerWidth;
    if (vw >= 1025) return {
      TX:      [0,   380,  690,  890],
      SCALE:   [1,   0.78, 0.58, 0.24],
      ROT:     [0,   12,   14,   16],
      BOT:     [0,  -10,  -20,  -30],
      OPA:     [1,   1,    1,    1],
      ZI:      [10,  7,    5,    3],
      DRAG_PX: 380
    };
    if (vw >= 501) return {
      TX:      [0,   240,  430,  560],
      SCALE:   [1,   0.78, 0.58, 0.24],
        ROT:     [0,   12,   14,   16],
      BOT:     [0,   -8,  -16,  -22],
      OPA:     [1,   1,    1,    1],
      ZI:      [10,  7,    5,    3],
      DRAG_PX: 240
    };
    return {
      TX:      [0,   210,  335,  420],
      SCALE:   [1,   0.75, 0.54, 0.22],
       ROT:     [0,   12,   14,   16],
      BOT:     [0,   -4,  -10,  -16],
      OPA:     [1,   1,    1,    1],
      ZI:      [10,  7,    5,    3],
      DRAG_PX: 160
    };
  }

  var MOMENTUM_DECAY = 0.88;
  var SNAP_STRENGTH  = 0.18;

  function lerp(a, b, t) { return a + (b - a) * Math.max(0, Math.min(1, t)); }
  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

  function interp(arr, absDiff) {
    var i0   = Math.min(Math.floor(absDiff), arr.length - 1);
    var i1   = Math.min(i0 + 1,              arr.length - 1);
    var frac = absDiff - Math.floor(absDiff);
    return lerp(arr[i0], arr[i1], frac);
  }

  function initCarousel(tabContent) {
    var slides    = Array.from(tabContent.querySelectorAll('.carousel-slide'));
    var infoCards = Array.from(tabContent.querySelectorAll('.product-info-card'));
    var total     = slides.length;
    if (total === 0) return;

    var offset       = Math.min(3, total - 1);
    var targetOffset = offset;
    var velocity     = 0;
    var activeIndex  = Math.round(offset);
    var rafId        = null;
    var animating    = false;

    var isDragging      = false;
    var dragStartX      = 0;
    var dragStartOffset = 0;
    var lastX           = 0;
    var lastT           = 0;

    var track = tabContent.querySelector('.carousel-track');

    function applyLayout(off) {
      var cfg = getCfg();
      slides.forEach(function (slide, i) {
        var diff    = i - off;
        var absDiff = Math.abs(diff);
        var sign    = diff >= 0 ? 1 : -1;

        var tx      = interp(cfg.TX,    absDiff) * sign;
        var scale   = interp(cfg.SCALE, absDiff);
        var rotate  = interp(cfg.ROT,   absDiff) * sign;
        var bottom  = interp(cfg.BOT,   absDiff);
        var opacity = absDiff > cfg.TX.length - 0.5 ? 0 : interp(cfg.OPA, absDiff);
        var z       = Math.round(interp(cfg.ZI, absDiff));

        slide.style.transform     = 'translateX(' + tx + 'px) scale(' + scale + ') rotate(' + rotate + 'deg)';
        slide.style.opacity       = opacity;
        slide.style.zIndex        = z;
        slide.style.bottom        = bottom + '%';
        slide.style.pointerEvents = (absDiff < 0.55) ? 'auto' : 'none';
      });
    }

    function syncCards() {
      var nearest = clamp(Math.round(offset), 0, total - 1);
      if (nearest === activeIndex) return;
      activeIndex = nearest;
      infoCards.forEach(function (card, i) {
        card.classList.toggle('active', i === activeIndex);
      });
    }

    function tick() {
      if (isDragging) { rafId = null; animating = false; return; }

      var nearest = clamp(Math.round(targetOffset), 0, total - 1);

      targetOffset += velocity;
      velocity     *= MOMENTUM_DECAY;

      var dist = nearest - targetOffset;
      targetOffset += dist * SNAP_STRENGTH;
      offset = targetOffset;

      applyLayout(offset);
      syncCards();

      if (Math.abs(dist) < 0.0003 && Math.abs(velocity) < 0.0003) {
        offset = nearest;
        targetOffset = nearest;
        velocity = 0;
        applyLayout(offset);
        syncCards();
        rafId = null;
        animating = false;
        return;
      }

      rafId = requestAnimationFrame(tick);
    }

    function startAnim() {
      if (!animating) { animating = true; rafId = requestAnimationFrame(tick); }
    }

    function dragStart(clientX) {
      if (rafId) { cancelAnimationFrame(rafId); rafId = null; animating = false; }
      isDragging      = true;
      dragStartX      = clientX;
      dragStartOffset = offset;
      lastX           = clientX;
      lastT           = performance.now();
      velocity        = 0;
      track.classList.add('dragging');
    }

    function dragMove(clientX) {
      if (!isDragging) return;
      var cfg = getCfg();
      var dx  = clientX - dragStartX;
      offset  = clamp(dragStartOffset - dx / cfg.DRAG_PX, -0.3, total - 0.7);

      var now = performance.now();
      var dt  = Math.max(1, now - lastT);
      velocity = -(clientX - lastX) / cfg.DRAG_PX / dt * 16;
      lastX = clientX;
      lastT = now;

      applyLayout(offset);
      syncCards();
    }

    function dragEnd() {
      if (!isDragging) return;
      isDragging = false;
      track.classList.remove('dragging');
      targetOffset = clamp(offset + velocity * 6, 0, total - 1);
      startAnim();
    }

    window.addEventListener('resize', function () {
      applyLayout(offset);
    });

    track.addEventListener('mousedown', function (e) { e.preventDefault(); dragStart(e.clientX); });
    document.addEventListener('mousemove', function (e) { dragMove(e.clientX); });
    document.addEventListener('mouseup',   function ()  { dragEnd(); });

    track.addEventListener('touchstart', function (e) { dragStart(e.touches[0].clientX); }, { passive: true });
    track.addEventListener('touchmove',  function (e) { dragMove(e.touches[0].clientX);  }, { passive: true });
    track.addEventListener('touchend',   function ()  { dragEnd(); },                       { passive: true });

    slides.forEach(function (slide, i) {
      slide.addEventListener('click', function () {
        if (Math.abs(velocity) > 0.01) return;
        var diff = i - Math.round(offset);
        if (diff !== 0) {
          targetOffset = clamp(offset + diff, 0, total - 1);
          velocity = 0;
          startAnim();
        }
      });
    });

    applyLayout(offset);
    syncCards();
  }

  function initTabs(section) {
    var tabBtns     = section.querySelectorAll('.tab_btn');
    var tabContents = section.querySelectorAll('.tab_content_item');
    tabBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var idx = btn.getAttribute('data-index');
        tabBtns.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        tabContents.forEach(function (c) { c.classList.remove('active'); });
        var target = section.querySelector('.tab_content_item[data-index="' + idx + '"]');
        if (target) target.classList.add('active');
      });
    });
  }

  function init() {
    document.querySelectorAll('section.custom_product_slider').forEach(function (section) {
      initTabs(section);
      section.querySelectorAll('.tab_content_item').forEach(function (tab) {
        initCarousel(tab);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

})();
</script>


{% schema %}
{
  "name": "Custom Product Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for the Journey"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Tab",
      "limit": 3,
      "settings": [
        {
          "type": "text",
          "id": "tab_1",
          "label": "Tab Label",
          "default": "Best Sellers"
        },
        { "type": "product",      "id": "product_1", "label": "Product 1" },
        { "type": "image_picker", "id": "image_1",   "label": "Custom Image 1" },
        { "type": "product",      "id": "product_2", "label": "Product 2" },
        { "type": "image_picker", "id": "image_2",   "label": "Custom Image 2" },
        { "type": "product",      "id": "product_3", "label": "Product 3" },
        { "type": "image_picker", "id": "image_3",   "label": "Custom Image 3" },
        { "type": "product",      "id": "product_4", "label": "Product 4" },
        { "type": "image_picker", "id": "image_4",   "label": "Custom Image 4" },
        { "type": "product",      "id": "product_5", "label": "Product 5" },


<section class="custom_faq">
  <div class="page-width">
    <div class="wrapper">

   {% if section.settings.sub_heading !=blank %}
   <p class="sub_heading">{{ section.settings.sub_heading }}</p>
    {% endif %} 
 {% if section.settings.heading !=blank %}
    <h2 class="heading">{{ section.settings.heading }}</h2>
    {% endif %}
<div class="faq_wrapper">
    
  {% for block in section.blocks %}
<div class="tab_heading_content_wrap">
    <div class="tab_heading_content">
 {% if block.settings.faq_heading !=blank %}
<h3 class="tab_heading">{{ block.settings.faq_heading }}

</h3>
  {% endif %}


    {% if block.settings.faq_content !=blank %}
<div class="tab_content" style="display:none;">{{ block.settings.faq_content }}</div>
{% endif %}
</div>
<div class="button_wrap">
<svg class="tab_hide" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" fill="none">
<rect x="0.5" y="0.5" width="35" height="35" rx="17.5" fill="#676D59"/>
<rect x="0.5" y="0.5" width="35" height="35" rx="17.5" stroke="#676D59"/>
<path d="M18 10C18.2652 10 18.5196 10.1054 18.7071 10.2929C18.8946 10.4804 19 10.7348 19 11V17H25C25.2652 17 25.5196 17.1054 25.7071 17.2929C25.8946 17.4804 26 17.7348 26 18C26 18.2652 25.8946 18.5196 25.7071 18.7071C25.5196 18.8946 25.2652 19 25 19H19V25C19 25.2652 18.8946 25.5196 18.7071 25.7071C18.5196 25.8946 18.2652 26 18 26C17.7348 26 17.4804 25.8946 17.2929 25.7071C17.1054 25.5196 17 25.2652 17 25V19H11C10.7348 19 10.4804 18.8946 10.2929 18.7071C10.1054 18.5196 10 18.2652 10 18C10 17.7348 10.1054 17.4804 10.2929 17.2929C10.4804 17.1054 10.7348 17 11 17H17V11C17 10.7348 17.1054 10.4804 17.2929 10.2929C17.4804 10.1054 17.7348 10 18 10Z" fill="#F8F6F5"/>
</svg>
<svg class="tab_show" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 36 36" fill="none">
<rect x="0.5" y="0.5" width="35" height="35" rx="17.5" stroke="#676D59"/>
<rect x="10" y="17.5" width="16" height="2" rx="1" fill="#676D59"/>
</svg>
</div>
</div>
  {% endfor %}
</div>

            </div>
            </div>
            </section>

            <style>
                section.custom_faq {
    background: rgba(247, 247, 243, 1);
    padding: 90px 0;
}
.custom_faq p.sub_heading {
    font-family: Instrument Sans;
    font-weight: 400;
    font-size: 18px;
    line-height: 20px;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 5.4px;
    color: rgba(103, 109, 89, 1);
    margin: 0;
}
.custom_faq h2.heading {
    font-family: Marcellus;
    font-weight: 400;
    font-size: 50px;
    line-height: 60px;
    text-align: center;
    color: rgba(103, 109, 89, 1);
    margin: 12px 0 0;
}

.custom_faq .faq_wrapper {
 width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: 50px;

}
.custom_faq .faq_wrapper .tab_heading_content_wrap {
     padding: 30px;
    border: 1px solid rgba(103, 109, 89, 1);
    display: grid;
    grid-template-columns: 1fr 35px;
    gap: 35px;
        cursor: pointer;
    {% comment %} align-items:center; {% endcomment %}

}
.custom_faq .faq_wrapper .tab_heading_content_wrap .button_wrap {
    font-size: 0;
}
.custom_faq .faq_wrapper .tab_heading_content_wrap .button_wrap svg {
    width: 100%;
}

.custom_faq .faq_wrapper .tab_heading_content_wrap.active{
    align-items: start;
}
.custom_faq .faq_wrapper .tab_heading_content_wrap h3.tab_heading {
    font-family: Instrument Sans;
    font-weight: 600;
    font-size: 20px;
    line-height: 22.95px;
    letter-spacing: 0px;
    vertical-align: middle;
    color: rgba(103, 109, 89, 1);
    margin: 0;

}
.custom_faq .faq_wrapper .tab_heading_content_wrap.active .button_wrap .tab_hide {
    display: none;
}
.custom_faq .faq_wrapper .tab_heading_content_wrap .tab_content p{
    font-family: Instrument Sans;
    font-weight: 400;
    font-size: 16px;
    line-height: 100%;
    letter-spacing: 0px;
        padding-top: 10px;
}
.custom_faq .faq_wrapper .tab_heading_content_wrap .tab_heading_content {
    display: flex;
    flex-direction: column;
        justify-content: center;

}
.custom_faq .faq_wrapper .tab_heading_content_wrap .tab_content p {
    margin: 0;
}

@media screen and (max-width: 1440px) {
section.custom_faq {
    padding: 60px 0;
}
}
@media screen and (max-width: 1280px) {
.custom_faq .faq_wrapper {
    gap: 15px;
    padding-top: 30px;
}
.custom_faq h2.heading {
    font-size: 40px;
    line-height: 50px;
    margin: 8px 0 0;
}
.custom_faq .faq_wrapper .tab_heading_content_wrap {
    padding: 20px;
    gap: 25px;
}
}
@media screen and (max-width: 1024px) {
.custom_faq p.sub_heading {
    font-size: 16px;
}
}
@media screen and (max-width: 768px) {
.custom_faq p.sub_heading {
    font-size: 14px;
    line-height: 18px;
}
    .custom_faq h2.heading {
        font-size: 34px;
        line-height: 42px;
    }
        .custom_faq .faq_wrapper .tab_heading_content_wrap {
        padding: 15px;
        gap: 15px;
            grid-template-columns: 1fr 25px;
    }
}

</style>


        <script>
        
$(document).ready(function() {
    // Default: open the first FAQ
    $(".custom_faq .tab_heading_content_wrap:first").addClass("active");
    $(".custom_faq .tab_heading_content_wrap:first .tab_content").show();
    $(".custom_faq .tab_heading_content_wrap:first .tab_open").hide();
    $(".custom_faq .tab_heading_content_wrap:first .tab_show").show();

    // On click
    $(".custom_faq .tab_heading_content_wrap").on("click", function() {
        var $this = $(this);

        if (!$this.hasClass("active")) {
            // Remove active from all
            $(".custom_faq .tab_heading_content_wrap").removeClass("active");
            $(".custom_faq .tab_content").slideUp();
            $(".custom_faq .tab_open").show();
            $(".custom_faq .tab_show").hide();

            // Add active to clicked
            $this.addClass("active");
            $this.find(".tab_content").slideDown();
            $this.find(".tab_open").hide();
            $this.find(".tab_show").show();
        } else {
            // If clicked active → close it
            $this.removeClass("active");
            $this.find(".tab_content").slideUp();
            $this.find(".tab_open").show();
            $this.find(".tab_show").hide();
        }
    });
});

  </script>
   {% schema %}
  {
    "name": "Custom Faq",
    "settings": [
       {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading"
    },
       {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
      



    ],
"blocks": [
      {
        "type": "block",
        "name":"Block",
        "settings": [
          
     
             {
      "type": "text",
      "id": "faq_heading",
      "label": "Faq Heading"
    },
{
      "type": "richtext",
      "id": "faq_content",
      "label": "Faq Content"
    },
               


        ]
      },
  
    ],

"presets": [
    {
      "name": "Custom Faq",
      "blocks": [
      ]
    }
  ]
  }

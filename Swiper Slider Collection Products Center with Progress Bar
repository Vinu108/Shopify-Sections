<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.best_sellling_rings').forEach(function (root) {
      root.querySelectorAll('.tab_btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var tabId = btn.getAttribute('data-tab');

          root.querySelectorAll('.tab_btn').forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');

          root.querySelectorAll('.tab_content').forEach(function (c) { c.classList.remove('active'); });

          var panel = root.querySelector('#' + tabId) || document.getElementById(tabId);
          if (!panel) return;
          panel.classList.add('active');

          if (tabId === 'tab-3') {
            panel.querySelectorAll('.product_card').forEach(function (card) {
              var firstLabel = card.querySelector('.options_with_value label');
              if (firstLabel) firstLabel.click();
            });
          }
        });
      });
    });
  });
</script>

